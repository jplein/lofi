<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- LSUIElement=YES: agent-style app. No Dock icon, no menu bar,
         no application-switcher entry. LoFi is invoked, does its work,
         and gets out of the way. -->
    <key>LSUIElement</key>
    <true/>

    <key>CFBundleIdentifier</key>
    <string>dev.jplein.lofi</string>

    <key>CFBundleName</key>
    <string>LoFi</string>

    <key>CFBundleDisplayName</key>
    <string>LoFi</string>

    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleExecutable</key>
    <string>LoFi</string>

    <key>NSHighResolutionCapable</key>
    <true/>

    <!-- Wording shown by the system the first time LoFi calls a
         Screen-Recording-gated API (e.g. CGRequestScreenCaptureAccess).
         Must be present before the first call or the prompt falls back
         to a generic system message. Window titles in CGWindowList are
         gated on this permission. -->
    <key>NSScreenCaptureUsageDescription</key>
    <string>LoFi lists your open windows so you can switch to one. Window titles are only readable with Screen Recording access.</string>
</dict>
</plist>
