use flake
PATH_add /Applications/Xcode.app/Contents/Developer/usr/bin
# Override the Nix-provided Darwin SDK path so Bazel's rules_swift /
# rules_apple find the real Xcode toolchain (xcrun, xcodebuild, the
# Swift compiler). The flake's devShell sets DEVELOPER_DIR to a
# nix-store SDK path that doesn't include the Swift toolchain or
# `xcrun --find swiftc` resolution; rules_swift then bails with
# "Could not determine Xcode version at all."
export DEVELOPER_DIR=/Applications/Xcode.app/Contents/Developer
